{
  "name": "override-styles",
  "private": true,
  "version": "1.0.0",
  "description": "ホストごとに任意の CSS を上書きする Google Chrome 拡張機能 (Manifest V3)",
  "type": "module",
  "license": "MIT",
  "author": "tnoriyuk-fsi",
  "repository": {
    "type": "git",
    "url": "https://github.com/tnoriyuk-fsi/override-styles.git"
  },
  "homepage": "https://github.com/tnoriyuk-fsi/override-styles#readme",
  "bugs": {
    "url": "https://github.com/tnoriyuk-fsi/override-styles/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "icons": "node scripts/generate-icons.mjs",
    "zip": "npm run build && node scripts/make-zip.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@eslint/js": "^9.39.4",
    "@types/chrome": "^0.0.287",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.9"
  }
}
