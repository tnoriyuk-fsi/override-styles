{
  "name": "override-styles",
  "private": true,
  "version": "1.0.0",
  "description": "ホストごとに任意の CSS を上書きする Google Chrome 拡張機能 (Manifest V3)",
  "type": "module",
  "license": "MIT",
  "author": "tnoriyuk-fsi",
  "repository": {
    "type": "git",
    "url": "https://github.com/tnoriyuk-fsi/override-styles.git"
  },
  "homepage": "https://github.com/tnoriyuk-fsi/override-styles#readme",
  "bugs": {
    "url": "https://github.com/tnoriyuk-fsi/override-styles/issues"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "icons": "node scripts/generate-icons.mjs",
    "zip": "npm run build && node scripts/make-zip.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "audit": "audit-ci --config ./audit-ci.jsonc",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.0",
    "@eslint/js": "^9.39.4",
    "@types/chrome": "^0.2.0",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "audit-ci": "^7.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "mermaid": "^11.15.0",
    "prettier": "^3.8.4",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{ts,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md,css,html,yml,yaml}": [
      "prettier --write --ignore-unknown"
    ]
  }
}
